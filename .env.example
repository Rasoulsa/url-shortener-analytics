# ── App ───────────────────────────────────────────────────
APP_NAME="URL Shortener & Analytics"
APP_VERSION="1.0.0"
BASE_URL="http://localhost:8000"
SHORT_CODE_LENGTH=7
DEBUG=true

# ── Postgres ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=urlshort
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Celery ─────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_RESULT_EXPIRES_SECONDS=3600
ANALYTICS_QUEUE_ENABLED=true

# ── Rate limiting ─────────────────────────────────────────
RATE_ANON_PER_MIN=100
RATE_AUTH_PER_MIN=1000

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_API_REQUESTS=100
RATE_LIMIT_REDIRECT_REQUESTS=60

# ── Caching ───────────────────────────────────────
HOT_LINK_THRESHOLD=50
HOT_LINK_EXTENDED_TTL=86400
DEFAULT_CACHE_TTL=3600

# ── Analytics ───────────────────────────────────────
GEOIP_DB_PATH=geoip/GeoLite2-City.mmdb
ANALYTICS_DEFAULT_DAYS=7
ANALYTICS_MAX_DAYS=90
CLICK_COUNTER_FLUSH_SECONDS=30

# ── Webhook ─────────────────────────
webhook_secret=dev-webhook-secret-change-me
ebhook_timeout_seconds=5
webhook_max_retries=5
webhook_user_agent=url-shortener-analytics-webhook/1.0
